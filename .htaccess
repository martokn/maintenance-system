RewriteEngine On

# Pass Authorization header through rewrite (required for JWT auth)
RewriteCond %{HTTP:Authorization} ^(.+)$
RewriteRule .* - [E=HTTP_AUTHORIZATION:%1]

# If the requested file or directory exists, serve it directly
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Forward PHP backend API routes
RewriteRule ^php-backend/(.*)$ php-backend/api/index.php?request=$1 [QSA,L]

# Forward all other requests to index.html for React Router
RewriteRule ^(.*)$ index.html [QSA,L]
